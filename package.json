{
  "name": "sysupdate_server",
  "version": "0.1.0",
  "module": "main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "bun test",
    "dev": "bun run --watch main.ts",
    "db:generate": "bun --env-file .env --bun drizzle-kit generate",
    "db:migrate": "bun --env-file .env --bun drizzle-kit migrate",
    "lint": "bunx biome lint --write",
    "formatter": "bunx biome format --write",
    "check": "bunx biome check --write",
    "format": "bun check && bun lint && bun formatter"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/semver": "^7.7.1",
    "biome": "^0.3.3",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "semver": "^7.7.4",
    "zod": "^4.3.6"
  }
}